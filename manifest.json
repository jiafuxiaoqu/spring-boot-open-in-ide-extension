{
    "manifest_version": 3,
    "name": "Spring Boot Open in IDE",
    "version": "1.2",
    "description": "在页面上捕获Spring Boot网络请求，并一键在IDEA中打开对应的控制器代码",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "webRequest"
    ],
    "host_permissions": [
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icon.png",
        "32": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "action": {
        "default_title": "Spring Boot Open in IDE",
        "default_icon": {
            "16": "icon.png",
            "32": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost/*",
                "https://localhost/*",
                "http://127.0.0.1/*",
                "https://127.0.0.1/*"
            ],
            "js": [
                "inject.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "http://localhost/*",
                "https://localhost/*",
                "http://127.0.0.1/*",
                "https://127.0.0.1/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ]
}